<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
  <!--
    JPA association accessors deliberately expose managed entity references. Copying these
    objects would detach them and break Hibernate's identity/dirty-checking semantics.
  -->
  <Match>
    <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    <Class name="~com\.gestproj\.backend\.(activitylog\.entity\.ActivityLog|member\.entity\.ProjectMember|notification\.entity\.Notification|project\.entity\.Project|projectinvitation\.entity\.ProjectInvitation|task\.entity\.(Task|TaskComment))"/>
  </Match>

  <!-- Spring injects shared collaborators; retaining those references is intentional. -->
  <Match>
    <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    <Class name="~com\.gestproj\.backend\.(activitylog\.controller\.ActivityLogController|activitylog\.service\.ActivityLogService|member\.controller\.ProjectMemberController|member\.service\.ProjectMemberService|notification\.service\.NotificationService|project\.controller\.ProjectController|project\.service\.ProjectService|projectinvitation\.service\.ProjectInvitationService|task\.controller\.(ProjectTaskController|TaskCommentController|TaskController)|task\.service\.(TaskCommentService|TaskSchedulerService|TaskService))"/>
  </Match>

  <!--
    JwtService is final, so a validation failure while constructing its HMAC key cannot be
    exploited through a subclass finalizer. SpotBugs reports CT_CONSTRUCTOR_THROW regardless.
  -->
  <Match>
    <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    <Class name="com.gestproj.backend.auth.jwt.JwtService"/>
  </Match>
</FindBugsFilter>
